# Required: Google Gemini API key (used for SERP grounding and SEO suggestions)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: SerpApi key — if set, used instead of Gemini for fetching SERP results
# Get one at https://serpapi.com
SERP_API_KEY=

# Optional: Gemini model to use (default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# Optional: API key to protect the /analyze endpoint via X-API-Key header
# Leave empty to disable authentication (not recommended in production)
API_KEY=your_secret_api_key_here
